# Core database/queue
POSTGRES_DB=ai_assistant
POSTGRES_USER=ai_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://ai_user:change_me@postgres:5432/ai_assistant
REDIS_URL=redis://redis:6379/0
TASK_QUEUE_NAME=tasks:queue

# Telegram
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_DELIVERY_TIMEOUT_SECONDS=15
TELEGRAM_FILE_DOWNLOAD_TIMEOUT_SECONDS=30

# Backend runtime
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://backend:8000

# Storage
STORAGE_INPUT_DIR=/storage/input
STORAGE_OUTPUT_DIR=/storage/output

# Worker / pipeline controls
WORKER_LOG_LEVEL=INFO
TASK_EXECUTOR=mock
MOCK_PROCESSING_DELAY_SECONDS=0.2
ATTACHMENT_TEXT_MAX_CHARS=50000
EXECUTION_INPUT_MAX_CHARS=120000
INSTRUCTION_TEXT_MAX_CHARS=8000
TELEGRAM_DELIVERY_MODE=live

# Mail provider adapters
MAILRU_IMAP_HOST=imap.mail.ru
MAILRU_IMAP_PORT=993
MAILRU_IMAP_USERNAME=
MAILRU_IMAP_PASSWORD=
MAILRU_IMAP_FOLDER=INBOX

# OpenAI (used when TASK_EXECUTOR=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_BASE_URL=https://api.openai.com

# DeepSeek/Kimi placeholders (not active in current MVP flow)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_BASE_URL=
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k
KIMI_TIMEOUT_SECONDS=30
KIMI_BASE_URL=

# Smoke/manual test overrides (optional)
API_BASE_URL=http://localhost:8000
REDIS_CONTAINER=ai_redis
POSTGRES_CONTAINER=ai_postgres
BACKEND_CONTAINER=ai_backend
WORKER_WAIT_TIMEOUT_SECONDS=40
WORKER_POLL_INTERVAL_SECONDS=1
WORKER_STARTUP_SLEEP_SECONDS=1
EXPECTED_FINAL_STATUS=done
PDF_SAMPLE_PATH=
